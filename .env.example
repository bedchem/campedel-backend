# =========================================
# Server Configuration
# =========================================

# Port auf dem die App läuft
PORT=3001

# Öffentliche URL deiner App
# Lokal:
BASE_URL=http://localhost:3001

# Beispiel Production:
# BASE_URL=https://deine-domain.com


# =========================================
# Security
# =========================================

# Admin Passwort für Login / Dashboard
ADMIN_PASSWORD=DEIN_SICHERES_PASSWORT

# Zufälliger geheimer Salt/Key
# Sollte lang und schwer erratbar sein
SECRET_SALT=EIN_LANGER_RANDOM_SECRET_KEY


# =========================================
# Uploads
# =========================================

# Ordner für hochgeladene Dateien
UPLOAD_DIR=./uploads


# =========================================
# Cloudflare Tunnel
# =========================================

# Optional:
# Token aus Cloudflare Zero Trust Dashboard
# https://dash.cloudflare.com/

# Leer lassen = Quick Tunnel ohne Account
TUNNEL_TOKEN=

# Beispiel:
# TUNNEL_TOKEN=eyJhIjoi...